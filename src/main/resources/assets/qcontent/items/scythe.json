{
  "model": {
    "type": "minecraft:select",
    "property": "minecraft:display_context",
    "cases": [
      {
        "when": "gui",
        "model": {
          "type": "minecraft:model",
          "model": "qcontent:item/scythe_gui"
        }
      },
      {
        "when": "ground",
        "model": {
          "type": "minecraft:model",
          "model": "qcontent:item/scythe_gui"
        }
      },
      {
        "when": "fixed",
        "model": {
          "type": "minecraft:model",
          "model": "qcontent:item/scythe"
        }
      }
    ],
    "fallback": {
      "type": "minecraft:condition",
      "property": "minecraft:using_item",
      "on_true": {
        "type": "minecraft:model",
        "model": "qcontent:item/scythe"
      },
      "on_false": {
        "type": "minecraft:model",
        "model": "qcontent:item/scythe"
      }
    }
  }
}
